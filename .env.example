# ── Imou Open Platform credentials ──────────────────────────────────────────
# Register at: https://open.imoulife.com/
# Go to: My Apps → Create App → get App ID and App Secret
IMOU_APP_ID=your_app_id_here
IMOU_APP_SECRET=your_app_secret_here

# Regional API endpoint — choose the closest to you:
#   Default (auto): https://openapi.easy4ip.com/openapi
#   Europe:         https://openapi-fk.easy4ip.com/openapi
#   Americas:       https://openapi-or.easy4ip.com/openapi
#   Asia/Pacific:   https://openapi-sg.easy4ip.com/openapi
IMOU_BASE_URL=https://openapi.easy4ip.com/openapi

# ── Flask security ────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ── Default admin account (created on first run) ──────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# ── App config ────────────────────────────────────────────────────────────────
PORT=5000
DEBUG=false
SESSION_LIFETIME_HOURS=8

# ── Database path (inside Docker: /data/) ────────────────────────────────────
DB_PATH=/data/imou_portal.db

# ── Webhook verification secret (optional) ───────────────────────────────────
# If set, incoming webhook requests must include this in X-Imou-Signature header
WEBHOOK_SECRET=
